[debug] [2026-06-20T16:56:12.672Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/duecentogrammi-2f6f1/rulesets {"name":"projects/duecentogrammi-2f6f1/rulesets/2a84b90b-9fc9-4f9c-a7a3-29f80838ef8c","source":{"files":[{"content":"rules_version = '2';\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    function isAdmin() {\r\n      return request.auth != null\r\n        && request.auth.token.email != null\r\n        && request.auth.token.email in [\"prova@prova.it\", \"mail@duecentogrammi.it\"];\r\n    }\r\n\r\n    match /reservations/{reservationId} {\r\n      allow read, create, update, delete: if isAdmin();\r\n    }\r\n\r\n    match /reservation_status/{code} {\n      allow read: if isAdmin();\n      allow create, update, delete: if isAdmin();\n    }\n\r\n    match /menu_items/{itemId} {\r\n      allow read: if true;\r\n      allow create, update, delete: if isAdmin();\r\n    }\r\n\r\n    match /menu_categories/{categoryId} {\r\n      allow read: if true;\r\n      allow create, update, delete: if isAdmin();\r\n    }\r\n\r\n    match /menu_ingredients/{ingredientId} {\r\n      allow read: if true;\r\n      allow create, update, delete: if isAdmin();\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-06-20T16:56:13.559967Z","metadata":{"services":["cloud.firestore"]}}
